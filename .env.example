# Locale de ce site (détermine la langue affichée)
SITE_LOCALE=en

# Thème visuel
THEME_KEY=elegant

# URL du CMS Payload central
NEXT_PUBLIC_CMS_URL=https://cms.zojewel.com
CMS_URL=https://cms.zojewel.com

# Secret ISR (doit correspondre au revalidateSecret dans SiteConfigs)
REVALIDATE_SECRET=change-me

# Stripe (clé publique uniquement côté Next.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Nom du domaine de ce site (pour les meta, sitemap, hreflang)
NEXT_PUBLIC_SITE_DOMAIN=zojewel.com
NEXT_PUBLIC_STORE_NAME=Velori
